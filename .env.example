# ======================================
# General
# ======================================
# Valid values: development | testing | staging | production
ENVIRONMENT=development
DEBUG=true


# ======================================
# Database
# ======================================
# URL selection logic in settings.py:
# - development -> DEV_DATABASE_URL (fallback: DATABASE_URL)
# - testing     -> TEST_DATABASE_URL (fallback: DATABASE_URL)
# - staging     -> DATABASE_URL
# - production  -> DATABASE_URL

# Primary URL used by staging/production.
DATABASE_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/schedule_builder_db

# Development database URL.
DEV_DATABASE_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/schedule_builder_dev

# Test database URL.
TEST_DATABASE_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/schedule_builder_test


# ======================================
# Auth / Security
# ======================================
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_API_TOKEN=change-me-admin-token


# ======================================
# AI Providers
# ======================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=...
